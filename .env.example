# Database
DATABASE_URL=postgresql://wallet_user:wallet_password@localhost:5432/WalletDB
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=WalletDB
DATABASE_USER=wallet_user
DATABASE_PASSWORD=wallet_password
DATABASE_SYNCHRONIZE=false

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=7d

# Environment
NODE_ENV=production
LOG_LEVEL=info

# API
API_PORT=3000
API_GLOBAL_PREFIX=api/v1
